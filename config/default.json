{
  "llm": {
    "backend": "stub",
    "max_tokens": 4096,
    "thinking_effort": "off",
    "thinking_format": "glm",
    "anthropic_proxy": {
      "base_url": "${ANTHROPIC_BASE_URL}",
      "api_key": "${ANTHROPIC_AUTH_TOKEN}",
      "model": "claude-opus-4-6",
      "max_tokens": 4096,
      "thinking_effort": "off",
      "thinking_format": "anthropic"
    },
    "ollama": {
      "base_url": "http://localhost:11434/v1",
      "api_key": "ollama",
      "model": "qwen3:8b",
      "max_tokens": 4096,
      "thinking_effort": "off",
      "thinking_format": "glm"
    },
    "openai_compat": {
      "base_url": "https://open.bigmodel.cn/api/paas/v4",
      "api_key": "${GLM_API_KEY}",
      "model": "glm-4.6",
      "max_tokens": 4096,
      "thinking_effort": "off",
      "thinking_format": "glm"
    },
    "glm_anthropic": {
      "base_url": "https://open.bigmodel.cn/api/anthropic",
      "api_key": "${GLM_API_KEY}",
      "model": "glm-4.6",
      "max_tokens": 4096,
      "thinking_effort": "off",
      "thinking_format": "anthropic"
    },
    "deepseek": {
      "base_url": "https://api.deepseek.com",
      "api_key": "${DEEPSEEK_API_KEY}",
      "model": "deepseek-v4-flash",
      "max_tokens": 4096,
      "thinking_effort": "off",
      "thinking_format": "openai"
    },
    "deepseek_anthropic": {
      "base_url": "https://api.deepseek.com/anthropic",
      "api_key": "${DEEPSEEK_API_KEY}",
      "model": "deepseek-v4-flash",
      "max_tokens": 4096,
      "thinking_effort": "off",
      "thinking_format": "anthropic"
    },
    "stub": {}
  },
  "embedder": {
    "backend": "hashing",
    "dim": 256,
    "openai_compat": {
      "base_url": "https://open.bigmodel.cn/api/paas/v4",
      "api_key": "${GLM_API_KEY}",
      "model": "embedding-3"
    }
  },
  "asr": {
    "backend": "stub",
    "language": "zh",
    "faster_whisper": {
      "model_size": "small",
      "device": "cpu",
      "compute_type": "int8",
      "vad_filter": true
    },
    "stub": {}
  },
  "speaker": {
    "backend": "text",
    "pyannote": {"hf_token_env": "HF_TOKEN"}
  },
  "web": {
    "backend": "bing",
    "api": {
      "format": "tavily",
      "api_key": "${TAVILY_API_KEY}",
      "base_url": "",
      "query_param": "q",
      "num_param": "num",
      "key_param": "api_key",
      "result_path": "results",
      "title_field": "title",
      "url_field": "url",
      "snippet_field": "content"
    }
  },
  "distill": {
    "reflection_interval_hours": 24,
    "min_segments_for_distill": 5,
    "profile_path": "data/persona/profile.json"
  },
  "proactive": {
    "check_interval_minutes": 30
  },
  "storage": {
    "sqlite_path": "data/db/personal_assistant.db",
    "duckdb_path": "data/db/analytics.duckdb"
  }
}
